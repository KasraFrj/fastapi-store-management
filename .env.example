# --- DATABASE CONFIGURATION ---
# آدرس اتصال به دیتابیس پستگرس داخل داکر (db نام سرویس کانتینر است)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD_HERE@db:5432/YOUR_DB_NAME_HERE

# اطلاعاتی که داکر کامپوز برای ساخت دیتابیس خام به آن‌ها نیاز دارد
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PASSWORD_HERE
POSTGRES_DB=YOUR_DB_NAME_HERE

# --- SECURITY & JWT CONFIGURATION ---
# یک رشته متنی تصادفی و طولانی برای امنیت توکن‌ها بگذارید
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30